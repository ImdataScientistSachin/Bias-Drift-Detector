# .env.example — Environment Variables for Bias Drift Guardian
# =============================================================
# INSTRUCTIONS:
#   1. Copy this file to .env (already .gitignored)
#   2. Fill in your actual values
#   3. Never commit .env to Git (it may contain secrets)
#
# IMP
#   "I follow the 12-Factor App methodology — all configuration
#    lives in environment variables, not hardcoded in code.
#    This means the same Docker image runs in dev, staging, and prod
#    with zero code changes."

# ─────────────────────────────────────────────
# ALERTING CONFIGURATION
# ─────────────────────────────────────────────

# Alert mode: mock (console print) | slack | email | all
# Use 'mock' for local development and demos — no external accounts needed
ALERT_MODE=mock

# Slack Incoming Webhook URL
# Get from: https://api.slack.com/apps → Your App → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Email Alert Settings (uses SMTP — Gmail App Password recommended)
ALERT_EMAIL_FROM=noreply@yourdomain.com
ALERT_EMAIL_TO=mlteam@yourdomain.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_PASSWORD=your_gmail_app_password_here

# ─────────────────────────────────────────────
# ALERT THRESHOLDS (Tune to your risk tolerance)
# ─────────────────────────────────────────────
PSI_ALERT_THRESHOLD=0.25          # Population Stability Index — 0.25 = "Moderate Drift"
FAIRNESS_SCORE_MIN=80             # Minimum acceptable Fairness Score out of 100

# ─────────────────────────────────────────────
# DVC REMOTE (for data versioning)
# ─────────────────────────────────────────────

# For local development:
DVC_REMOTE_TYPE=local
DVC_REMOTE_PATH=./dvc-remote

# For production (S3 example):
# DVC_REMOTE_TYPE=s3
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# DVC_REMOTE_PATH=s3://your-bucket/dvc-cache

# ─────────────────────────────────────────────
# API CONFIGURATION
# ─────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ─────────────────────────────────────────────
# MLFLOW TRACKING
# ─────────────────────────────────────────────
MLFLOW_TRACKING_URI=./mlruns              # Local (default)
# MLFLOW_TRACKING_URI=http://mlflow:5000  # Remote MLflow server (production)
